# .env.example
# 실제 배포시 이 파일을 참고하여 환경변수를 설정하세요

# PostgreSQL Database URL (Vercel Postgres, Supabase, 또는 다른 PostgreSQL 서비스)
DATABASE_URL="postgresql://username:password@host:port/database"

# 관리자 비밀번호 (보안을 위해 복잡한 비밀번호 사용 권장)
ADMIN_PASSWORD="your_secure_admin_password"

# 쿠키 암호화 시크릿 (랜덤한 32자 이상의 문자열)
COOKIE_SECRET="your_random_secret_key_here"